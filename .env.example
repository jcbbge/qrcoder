# Shopify
SHOPIFY_SHOP_NAME=harding-art-show
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify Webhook Verification (API Secret Key from Partners dashboard)
SHOPIFY_WEBHOOK_SECRET=your_api_secret_key_here

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server
PORT=3000
NODE_ENV=production
